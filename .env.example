# Rename to .env and add your keys
OPENAI_API_KEY="sk-..."

# Postgres Config
PGHOST="localhost"
PGPORT="5432"
PGUSER="postgres"
PGPASSWORD=""
PGDATABASE="vendor_mcp"

# MCP Server
PORT="8765"
MCP_CLIENT_ID="vendor-mcp-"
MCP_CLIENT_SECRET=""
# Public URL — set to your Cloudflare tunnel hostname
MCP_PUBLIC_URL="https://vendor.ssc.one"

# GitHub OAuth App (create at https://github.com/settings/developers)
# Set Authorization callback URL to: https://vendor.ssc.one/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_SECRET=""
GITHUB_OAUTH_CALLBACK_URL="https://vendor.ssc.one/auth/github/callback"

# Set to "true" to require GitHub OAuth authentication on the /mcp endpoint
REQUIRE_AUTH="true"

# Cloudflare Tunnel
# Tunnel is configured via cloudflared config file inside the container.
# Credentials live in the Docker volume: vendor-mcp_cloudflared-certs
# To set up on a fresh deployment:
#   docker exec -it vendor-mcp-server sh
#   cloudflared tunnel login
#   cloudflared tunnel create vendor-mcp
#   cloudflared tunnel route dns vendor-mcp vendor.ssc.one
# Then add config.yml to /root/.cloudflared/ (see mcp/Dockerfile CMD)
# The tunnel auto-starts on container restart once credentials are in the volume.
